APP_NAME=Company Reputation Monitor API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/reputation_monitor
DEFAULT_TIMEZONE=Asia/Shanghai
DEFAULT_BRAND_KEYWORDS=公司,品牌,产品

POSTGRES_DB=reputation_monitor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=articles

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false

NLP_PROVIDER=mock
NLP_API_KEY=

# Anthropic Claude API（用于情感分析，留空则退回关键词启发式）
ANTHROPIC_API_KEY=

NOTIFICATION_CHANNEL=feishu
NOTIFICATION_WEBHOOK=

REPORT_OUTPUT_DIR=./apps/web/public/exports
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
