{
  "name": "company-reputation-monitor",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "cd apps/api && python3 -m uvicorn app.main:app --reload --port 8000",
    "dev:worker": "cd apps/api && .venv/bin/celery -A app.tasks.celery_app:celery_app worker --loglevel=info",
    "check:api": "python3 -m compileall apps/api/app",
    "infra:up": "docker compose up -d postgres elasticsearch redis",
    "infra:down": "docker compose down"
  }
}